# Template for the local stack's .env — copy to .env and set real values.
#   cp .env.example .env
# .env is gitignored; this template is committed so the stack is reproducible.

# Database name created on first start and used by the API.
POSTGRES_DB=ecommerce_db
# Root/superuser for the postgres container.
POSTGRES_USER=postgres
# Password for POSTGRES_USER. Use a real secret; never commit the filled-in .env.
POSTGRES_PASSWORD=local_dev_change_me
LOG_PATH=/app/logs
LOG_FILE_NAME=ecommerce-api
HOST_LOG_PATH=./logs
